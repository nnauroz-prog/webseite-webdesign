# --- Supabase ---
# Project URL — found under Supabase dashboard > Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Anonymous (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side ONLY. Never expose to the browser.
# Used in Phase 7 (admin actions) and seed scripts.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
# Public canonical URL of the SitePilot app, used in metadata and emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000
