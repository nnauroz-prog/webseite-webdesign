# --- Anthropic API (Hero-Chat-Assistent) ---
# API-Key von https://console.anthropic.com → API Keys. Server-side ONLY.
# Ohne diesen Key liefert /api/chat eine ruhige 503-Antwort und der
# Hero-Chat zeigt einen Hinweis, statt zu crashen.
ANTHROPIC_API_KEY=

# --- Site URL ---
# Öffentliche Canonical-URL — wird in Metadata, robots.txt und sitemap.xml
# verwendet. Lokal: http://localhost:3000, Production: https://www.sitalo.de.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Formspree (Lead-Mail-Transport für /anfrage) ---
# Form-ID von https://formspree.io → Forms → New Form. Mit der E-Mail
# einloggen, auf die Anfragen kommen sollen. Die Form-ID ist der Teil
# nach /f/ in der Form-URL (z. B. "mqkvpyzr"). Ohne diesen Wert ist der
# Submit-Button deaktiviert.
FORMSPREE_FORM_ID=
