# --- Supabase ---
# Project URL — found under Supabase dashboard > Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Anonymous (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side ONLY. Never expose to the browser.
# Required by Stripe webhook to update subscription rows under RLS.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
# Public canonical URL of the SitePilot app, used in metadata and emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stripe ---
# Secret key — server-side ONLY. Find under stripe.com → Developers → API keys.
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — created when you register the /api/stripe/webhook
# endpoint under stripe.com → Developers → Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_...

# Recurring monthly Price IDs — create three Products in Stripe (Basic, Pro,
# Premium), one Price each (recurring/monthly), then paste their IDs here.
NEXT_PUBLIC_STRIPE_PRICE_BASIC=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_...
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM=price_...

# --- Lemon Squeezy (alternative payment provider, parallel to Stripe) ---
# Pick which provider the checkout button hits. "stripe" (default) or "lemon".
# Public so the client component can route to the right endpoint.
NEXT_PUBLIC_BILLING_PROVIDER=stripe

# API key from lemonsqueezy.com → Settings → API. Server-side ONLY.
LEMONSQUEEZY_API_KEY=

# Store ID — found in the URL of your store dashboard.
LEMONSQUEEZY_STORE_ID=

# Webhook signing secret — set when registering the /api/lemon/webhook
# endpoint under Settings → Webhooks.
LEMONSQUEEZY_WEBHOOK_SECRET=

# Variant IDs for each plan. Create one Product per plan in Lemon, then
# copy each variant ID from the product detail page.
LEMONSQUEEZY_VARIANT_BASIC=
LEMONSQUEEZY_VARIANT_PRO=
LEMONSQUEEZY_VARIANT_PREMIUM=

# --- Vercel API (optional, for automated custom-domain attachment) ---
# When set, Sitalo automatically attaches/detaches customer domains
# in your Vercel project via the REST API. Without this, custom-domain
# requests still save to the DB but the operator has to add the domain
# in Vercel manually + set custom_domain_verified_at in Supabase.
#
# Token: Vercel → Account Settings → Tokens. Scope = read/write project.
VERCEL_API_TOKEN=
# Project ID: Vercel → Your Project → Settings → General → Project ID.
VERCEL_PROJECT_ID=
# Team ID (optional, only if the project lives under a team).
VERCEL_TEAM_ID=

# --- AI image generation (optional) ---
# Google Gemini Imagen / "Nano Banana 2" API key. Generated under
# https://aistudio.google.com — Free-tier covers limited daily quota,
# Pay-as-you-go is ~$0.04 per image. Server-side ONLY.
# Without this set, the "✨ KI generieren" buttons in the dashboard
# show a friendly "nicht verfügbar" message instead of crashing.
GOOGLE_API_KEY=

# --- Unsplash (stock photos, optional) ---
# Access key from https://unsplash.com/oauth/applications → New
# Application. Free tier is 50 requests/hour and covers the typical
# dashboard usage. Server-side ONLY — the key is proxied through
# /api/unsplash/search, never exposed to the browser. Without this,
# the "Stock-Foto wählen" buttons show "nicht konfiguriert" instead
# of crashing.
UNSPLASH_ACCESS_KEY=

# --- Sitalo agency contact ---
# Internal email that receives every project inquiry submitted via
# /anfrage. Server-side only. Falls back to hallo@sitalo.de in dev.
# Preferred name:
LEAD_NOTIFICATION_EMAIL=
# Legacy name, still read as a fallback for backwards compatibility:
SITALO_INQUIRY_TO=hallo@sitalo.de

# --- Formspree (preferred lead mail transport) ---
# Get a form ID at https://formspree.io → Forms → New Form. Sign in
# with the email you want to receive inquiries on. The form ID is
# the bit after /f/ in the form URL, e.g. "mqkvpyzr".
#
# When this is set, /anfrage uses Formspree for lead delivery (no
# domain reputation issues, generous free tier). When unset, the
# action falls back to Resend via RESEND_API_KEY + MAIL_FROM below.
FORMSPREE_FORM_ID=

# Phone number for the floating WhatsApp CTA on the marketing pages
# (landing, pricing, /anfrage). Format: digits only or +49…, no
# spaces required (we strip non-digits). Without this var the button
# is hidden — better than linking to nowhere.
NEXT_PUBLIC_SITALO_WHATSAPP_NUMBER=
# Optional pre-filled message for the WhatsApp chat. Leave empty for
# a sensible default greeting in German.
NEXT_PUBLIC_SITALO_WHATSAPP_MESSAGE=

# --- Cron jobs ---
# Shared secret for Vercel Cron invocations (Authorization: Bearer <SECRET>).
# Generate with: openssl rand -base64 32
CRON_SECRET=

# --- Resend (transactional email) ---
# API key from resend.com → API Keys. Notifications are best-effort:
# if RESEND_API_KEY is unset, leads still save, only email is skipped.
RESEND_API_KEY=re_...

# Verified sender address. Defaults to onboarding@resend.dev which works
# without DNS setup for testing. For production, verify your own domain
# in Resend and use e.g. "Sitalo <noreply@deine-domain.de>".
MAIL_FROM=Sitalo <onboarding@resend.dev>
